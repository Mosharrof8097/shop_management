generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ──────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
}

enum PaymentType {
  CASH
  CREDIT
  PARTIAL
}

enum PaymentMethod {
  CASH
  BKASH
  NAGAD
  ROCKET
  CHECK
  BANK_TRANSFER
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum PurchaseStatus {
  COMPLETED
  PARTIAL
  PENDING
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum StockMovementType {
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
  DAMAGE
  OPENING
}

enum TransactionType {
  SALE
  PAYMENT
  ADJUSTMENT
  RETURN
}

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARY_WAGES
  REPAIRS
  TRANSPORT
  OTHER
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── MODEL: Shop (Tenant Root — SaaS base) ─────────────────────────────────

model Shop {
  id                 String           @id @default(uuid())
  name               String
  address            String?
  phone              String?
  email              String?
  logoUrl            String?
  currency           String           @default("BDT")
  subscriptionPlan   SubscriptionPlan @default(FREE)
  subscriptionEndsAt DateTime?
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  users                User[]
  categories           Category[]
  products             Product[]
  customers            Customer[]
  suppliers            Supplier[]
  sales                Sale[]
  purchases            Purchase[]
  expenses             Expense[]
  stockMovements       StockMovement[]
  customerTransactions CustomerTransaction[]
  paymentRequests      PaymentRequest[]

  @@index([isActive])
}

// ── MODEL: User (Staff) ────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  shopId       String?
  name         String
  email        String
  passwordHash String
  role         UserRole  @default(CASHIER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  shop           Shop?           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sales          Sale[]
  purchases      Purchase[]
  expenses       Expense[]
  stockMovements StockMovement[]

  @@unique([email])
  @@index([shopId])
  @@index([email])
}

// ── MODEL: Category ────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  shopId      String
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([shopId, name])
  @@index([shopId])
}

// ── MODEL: Product ─────────────────────────────────────────────────────────

model Product {
  id            String    @id @default(uuid())
  shopId        String
  categoryId    String?
  name          String
  sku           String?
  barcode       String?
  purchasePrice Decimal   @db.Decimal(12, 2)
  sellingPrice  Decimal   @db.Decimal(12, 2)
  currentStock  Int       @default(0)
  minStockAlert Int       @default(5)
  unit          String    @default("পিস")
  imageUrl      String?
  isActive      Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  shop           Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category       Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  stockMovements StockMovement[]

  @@unique([shopId, sku])
  @@index([shopId])
  @@index([shopId, categoryId])
  @@index([shopId, isActive, currentStock])
  @@index([shopId, deletedAt])
  @@index([sku])
  @@index([barcode])
}

// ── MODEL: StockMovement (Full Audit Trail) ───────────────────────────────

model StockMovement {
  id             String            @id @default(uuid())
  shopId         String
  productId      String
  type           StockMovementType
  referenceId    String?
  referenceType  String?
  quantityBefore Int
  quantityChange Int
  quantityAfter  Int
  reason         String?
  userId         String?
  createdAt      DateTime          @default(now())

  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([shopId, productId])
  @@index([shopId, createdAt])
  @@index([productId, createdAt])
  @@index([referenceId, referenceType])
}

// ── MODEL: Customer ────────────────────────────────────────────────────────

model Customer {
  id          String         @id @default(uuid())
  shopId      String
  name        String
  phone       String?
  address     String?
  email       String?
  totalDue    Decimal        @default(0) @db.Decimal(12, 2)
  creditLimit Decimal?       @db.Decimal(12, 2)
  status      CustomerStatus @default(ACTIVE)
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  shop         Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sales        Sale[]
  transactions CustomerTransaction[]

  @@index([shopId])
  @@index([shopId, status])
  @@index([shopId, totalDue])
  @@index([shopId, deletedAt])
  @@index([phone])
}

// ── MODEL: CustomerTransaction (Running Ledger) ───────────────────────────

model CustomerTransaction {
  id             String          @id @default(uuid())
  shopId         String
  customerId     String
  date           DateTime        @default(now())
  type           TransactionType
  invoiceNo      String?
  description    String?
  debit          Decimal         @default(0) @db.Decimal(12, 2)
  credit         Decimal         @default(0) @db.Decimal(12, 2)
  runningBalance Decimal         @db.Decimal(12, 2)
  paymentMethod  PaymentMethod?
  createdAt      DateTime        @default(now())

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([shopId, customerId])
  @@index([customerId, date])
  @@index([shopId, date])
}

// ── MODEL: Supplier ────────────────────────────────────────────────────────

model Supplier {
  id            String         @id @default(uuid())
  shopId        String
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  totalDue      Decimal        @default(0) @db.Decimal(12, 2)
  status        SupplierStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  shop      Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  purchases Purchase[]

  @@index([shopId])
  @@index([shopId, status])
}

// ── MODEL: Sale (Invoice Header) ──────────────────────────────────────────

model Sale {
  id            String        @id @default(uuid())
  shopId        String
  invoiceNo     String
  customerId    String?
  customerName  String?
  saleDate      DateTime      @default(now())
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  paidAmount    Decimal       @db.Decimal(12, 2)
  dueAmount     Decimal       @default(0) @db.Decimal(12, 2)
  paymentType   PaymentType   @default(CASH)
  paymentMethod PaymentMethod @default(CASH)
  notes         String?
  status        SaleStatus    @default(COMPLETED)
  userId        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  items    SaleItem[]

  @@unique([shopId, invoiceNo])
  @@index([shopId])
  @@index([shopId, saleDate])
  @@index([shopId, customerId])
  @@index([shopId, status])
  @@index([customerId, saleDate])
}

// ── MODEL: SaleItem (Line items with product snapshots) ───────────────────

model SaleItem {
  id          String   @id @default(uuid())
  saleId      String
  productId   String
  productName String
  productSku  String?
  quantity    Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
  @@index([productId, createdAt])
}

// ── MODEL: Purchase (Purchase Invoice) ────────────────────────────────────

model Purchase {
  id           String         @id @default(uuid())
  shopId       String
  supplierId   String?
  invoiceNo    String?
  purchaseDate DateTime       @default(now())
  subtotal     Decimal        @db.Decimal(12, 2)
  total        Decimal        @db.Decimal(12, 2)
  paidAmount   Decimal        @db.Decimal(12, 2)
  dueAmount    Decimal        @default(0) @db.Decimal(12, 2)
  status       PurchaseStatus @default(COMPLETED)
  notes        String?
  userId       String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  shop     Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  user     User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  items    PurchaseItem[]

  @@unique([shopId, invoiceNo])
  @@index([shopId])
  @@index([shopId, purchaseDate])
  @@index([shopId, supplierId])
}

// ── MODEL: PurchaseItem (with product snapshots) ──────────────────────────

model PurchaseItem {
  id          String   @id @default(uuid())
  purchaseId  String
  productId   String
  productName String
  quantity    Int
  unitCost    Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([productId])
}

// ── MODEL: Expense ─────────────────────────────────────────────────────────

model Expense {
  id            String          @id @default(uuid())
  shopId        String
  date          DateTime        @default(now())
  category      ExpenseCategory
  description   String
  amount        Decimal         @db.Decimal(12, 2)
  paymentMethod PaymentMethod   @default(CASH)
  notes         String?
  userId        String?
  createdAt     DateTime        @default(now())

  shop Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([shopId, date])
  @@index([shopId, category])
}

// ── MODEL: PaymentRequest (Subscription renewal requests) ─────────────────

model PaymentRequest {
  id        String           @id @default(uuid())
  shopId    String
  trxId     String
  method    String           @default("BKASH")
  plan      SubscriptionPlan
  months    Int              @default(1)
  amount    Decimal          @db.Decimal(10, 2)
  status    PaymentStatus    @default(PENDING)
  note      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([status])
  @@index([createdAt])
}
